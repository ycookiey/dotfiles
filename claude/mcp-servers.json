{
  "tavily": {
    "command": "npx",
    "args": ["-y", "tavily-mcp@latest"],
    "env": {
      "TAVILY_API_KEY": "{TAVILY_API_KEY}"
    }
  },
  "gtr": {
    "command": "node",
    "args": ["{PROJECTS}/gtr-mcp-server/build/index.js"],
    "env": {
      "PATH": "{PROJECTS}/git-worktree-runner/bin;{HOME}/scoop/apps/git/current/mingw64/bin;{HOME}/scoop/apps/git/current/usr/bin;C:/Program Files/nodejs",
      "GTR_BASH_PATH": "{HOME}/scoop/apps/git/current/usr/bin/bash.exe"
    }
  },
  "ytasky": {
    "command": "ytasky",
    "args": ["mcp"]
  },
  "pencil": {
    "command": "{LOCALAPPDATA}/Programs/Pencil/resources/app.asar.unpacked/out/mcp-server-windows-x64.exe",
    "args": ["--app", "desktop"]
  },
  "git-polite": {
    "command": "uvx",
    "args": ["git-polite@git+https://github.com/uneco/mcp-git-polite.git", "mcp"]
  }
}
